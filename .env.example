# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
INITIAL_ADMIN_EMAIL=admin@kabi-consulting.de

# Supabase DEV for local development and Vercel Preview
NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key

# Server-only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# Vercel Production uses the same variable names with KABI PROD values:
# NEXT_PUBLIC_APP_URL=https://kabi-zeiterfassung.vercel.app
# NEXT_PUBLIC_SUPABASE_URL=https://your-prod-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-prod-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key
